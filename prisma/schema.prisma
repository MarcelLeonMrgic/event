generator client {
  provider   = "prisma-client"
  output     = "../app/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Signup {
  id        String   @id @default(cuid())
  alias     String
  phone     String
  shiftId   String
  createdAt DateTime @default(now())
}